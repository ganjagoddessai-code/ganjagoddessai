  "config": {
    "port": 3000,
    "env": "development",
    "ai_model": "ghost-agent-v1",
    "render_engine": "threejs",
    "simulation_mode": "enabled",
    "print_mode": "3dpod",
    "ar_mode": "enabled",
    "vr_mode": "enabled",

    "agent_mode": "autonomous",
    "orchestration_mode": "event-driven",
    "memory_system": "vector-graph",
    "data_pipeline": "streaming",
    "render_pipeline": "webgl2",
    "physics_engine": "gpu-accelerated",
    "commerce_mode": "ghost-autopilot"
