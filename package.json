{
  "name": "ghost-3dpod-store",
  "version": "1.0.0",
  "description": "👻 Ghost Agentic 3DPoD AR/VR Print-on-Demand Commerce System with AI agents, real-time orchestration, and spatial UI rendering pipeline",
  "main": "server.js",
  "type": "commonjs",

  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "build": "echo \"No build step defined\"",
    "clean": "rm -rf node_modules",
    "reset": "npm run clean && npm install",
    "debug": "node --inspect server.js",
    "watch": "nodemon server.js",
    "prod": "NODE_ENV=production node server.js",

    "ai:train": "node ai/train.js",
    "ai:infer": "node ai/infer.js",
    "agent:spawn": "node agents/spawn.js",
    "agent:sync": "node agents/sync.js",

    "ar:build": "node ar/build.js",
    "vr:build": "node vr/build.js",

    "3d:compile": "node pipelines/3d-compile.js",
    "3d:optimize": "node pipelines/optimize.js",

    "db:migrate": "node db/migrate.js",
    "db:seed": "node db/seed.js",

    "queue:start": "node queues/worker.js",
    "queue:flush": "node queues/flush.js",

    "deploy": "bash deploy.sh",
    "docker:build": "docker build -t ghost-3dpod .",
    "docker:run": "docker run -p 3000:3000 ghost-3dpod",

    "metrics:collect": "node observability/metrics.js",
    "logs:stream": "node observability/log-stream.js",
    "healthcheck": "node observability/healthcheck.js",

    "security:scan": "node security/scan.js",
    "security:audit": "npm audit",

    "backup:db": "node backup/db-backup.js",
    "restore:db": "node backup/db-restore.js",

    "sync:cdn": "node infra/cdn-sync.js",
    "sync:assets": "node infra/assets-sync.js",

    "edge:deploy": "node edge/deploy.js",
    "edge:rollback": "node edge/rollback.js",

    "ai:evaluate": "node ai/evaluate.js",
    "ai:benchmark": "node ai/benchmark.js",

    "vector:index": "node vector/index.js",
    "vector:search": "node vector/search.js",

    "realtime:start": "node realtime/server.js",
    "realtime:scale": "node realtime/scale.js",

    "marketplace:sync": "node marketplace/sync.js",
    "marketplace:price": "node marketplace/pricing-engine.js",

    "3d:render": "node pipelines/render.js",
    "3d:validate": "node pipelines/validate.js",

    "xr:sync": "node xr/sync.js",
    "xr:deploy": "node xr/deploy.js",

    "workflow:run": "node workflows/runner.js",
    "workflow:build": "node workflows/builder.js"
  },

