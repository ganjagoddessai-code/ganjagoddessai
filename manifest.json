  "id": "ganjagoddessai.app",

  "prefer_related_applications": false,

  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://ganjagoddessai.com"
    }
  ],

  "edge_side_panel": {
    "preferred_width": 420
  },

  "launch_handler": {
    "client_mode": "navigate-existing"
  },

  "handle_links": "preferred",

  "capture_links": "existing-client-navigate",

  "orientation_lock": "natural",

  "protocol_handlers": [
    {
      "protocol": "web+goddessai",
      "url": "/intent?data=%s"
    },
    {
      "protocol": "web+3dpod",
      "url": "/3dpod/intent?data=%s"
    },
    {
      "protocol": "web+xr",
      "url": "/xr/intent?data=%s"
    },
    {
      "protocol": "web+ghostcommerce",
      "url": "/commerce?intent=%s"
    },
    {
      "protocol": "web+orbit",
      "url": "/orbit?node=%s"
    }
  ],

  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "media",
          "accept": [
            "image/*",
            "video/*",
            "application/pdf",
            "model/*",
            "audio/*"
          ]
        }
      ]
    }
  },

  "file_handlers": [
    {
      "action": "/files",
      "accept": {
        "image/*": [
          ".png",
          ".jpg",
          ".jpeg",
          ".webp",
          ".gif",
          ".svg"
        ],
        "application/pdf": [
          ".pdf"
        ],
        "text/plain": [
          ".txt",
          ".md"
        ],
        "model/*": [
          ".obj",
          ".glb",
          ".gltf",
          ".stl",
          ".fbx"
        ],
        "audio/*": [
          ".mp3",
          ".wav",
          ".ogg"
        ],
        "video/*": [
          ".mp4",
          ".webm"
        ]
      }
    }
  ],

  "scope_extensions": [
    {
      "origin": "https://ganjagoddessai.com"
    },
    {
      "origin": "https://cdn.ganjagoddessai.com"
    },
    {
      "origin": "https://api.ganjagoddessai.com"
    }
  ],

  "permissions_policy": {
    "camera": ["self"],
    "microphone": ["self"],
    "geolocation": ["self"],
    "fullscreen": ["self"],
    "xr-spatial-tracking": ["self"],
    "usb": ["self"],
    "screen-wake-lock": ["self"],
    "clipboard-read": ["self"],
    "clipboard-write": ["self"],
    "gyroscope": ["self"],
    "accelerometer": ["self"],
    "payment": ["self"],
    "notifications": ["self"]
  },

  "background": {
    "theme": "orbital-smoke-neural-grid",
    "particles": true,
    "dynamic_lighting": true,
    "shader_pipeline": "webgl2",
    "parallax_depth": true
  },

  "ai_system": {
    "default_persona": "ganjagoddess",
    "voice_enabled": true,
    "memory_mode": "persistent",
    "emotion_engine": true,
    "intent_detection": true,
    "semantic_navigation": true,
    "predictive_suggestions": true,
    "multi_agent_mode": true
  },

  "commerce": {
    "ghost_mode": true,
    "dropshipping": true,
    "eco_friendly_only": true,
    "3dpod_enabled": true,
    "affiliate_engine": true,
    "dynamic_pricing": true,
    "smart_upsells": true,
    "autonomous_recommendations": true
  },

  "xr_features": {
    "ar_enabled": true,
    "vr_enabled": true,
    "webxr_enabled": true,
    "hand_tracking": true,
    "spatial_audio": true,
    "3d_environment": true
  },

  "performance": {
    "adaptive_rendering": true,
    "low_power_mode": true,
    "gpu_acceleration": true,
    "lazy_loading": true,
    "offline_shell": true,
    "streaming_assets": true
  }
}